FROM alpine:3.21

ARG TARGETOS
ARG TARGETARCH

RUN apk add --no-cache ca-certificates tzdata

COPY ${TARGETOS}/${TARGETARCH}/NookClaw /usr/local/bin/nookclaw
COPY ${TARGETOS}/${TARGETARCH}/nookclaw-launcher /usr/local/bin/nookclaw-launcher
COPY ${TARGETOS}/${TARGETARCH}/nookclaw-launcher-tui /usr/local/bin/nookclaw-launcher-tui

ENTRYPOINT ["nookclaw-launcher"]
CMD ["-public", "-no-browser"]
